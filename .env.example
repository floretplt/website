# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
# Use either name — same key from Supabase → Settings → API ("anon" / "publishable")
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_LIQPAY_PUBLIC_KEY=
# Google Maps JavaScript API (Places) — address autocomplete on the order form
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server only
SUPABASE_SERVICE_ROLE_KEY=
LIQPAY_PRIVATE_KEY=
# Optional: HMAC secret for prepay checkout cookie (falls back to LIQPAY_PRIVATE_KEY)
ORDER_CHECKOUT_SECRET=
# Optional: public callback URL for LiqPay server (when NEXT_PUBLIC_SITE_URL is localhost).
# Example: https://www.floret.poltava.ua/api/liqpay/callback
# LIQPAY_SERVER_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secret for POST /api/telegram/webhook (setWebhook secret_token); required in production
TELEGRAM_WEBHOOK_SECRET=

# Optional: restrict admin panel to this email (Supabase Auth)
ADMIN_EMAIL=

# Optional but recommended in production: Upstash Redis (multi-instance safe
# rate-limit). Without these the app falls back to a per-instance in-memory
# limiter — fine for local dev, leaky on Vercel where requests fan out.
# Create at https://console.upstash.com → Redis → "REST" tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
